{
  "$schema": "https://unpkg.com/@aliou/pi-guardrails@0.13.1/schema.json",
  "features": {
    "policies": true,
    "permissionGate": true,
    "pathAccess": false
  },
  "permissionGate": {
    "autoDenyPatterns": [
      {
        "pattern": "(?:^|[;&|()])\\s*rm\\b(?=[^;&|()]*\\s(?:-[A-Za-z]*[rR][A-Za-z]*|--recursive)\\b)(?=[^;&|()]*\\s(?:-[A-Za-z]*[fF][A-Za-z]*|--force)\\b)[^;&|()]*\\s(?:--\\s+)?(?:/|~/?|\\./?)(?=\\s|$|[;&|()])",
        "regex": true
      },
      ":(){ :|:& };:",
      {
        "pattern": "(^|[;&|()\\s])dd\\s+.*\\bof=/dev/",
        "regex": true
      },
      "mkfs",
      {
        "pattern": "(?:^|[;&|()])\\s*git\\b(?:\\s+(?:(?:-C|-c|--git-dir|--work-tree|--namespace)\\s+\\S+|(?:--git-dir|--work-tree|--namespace)=\\S+|-[A-Za-z]+|--[A-Za-z0-9-]+))*\\s+(?:add|am|apply|bisect|branch|checkout|cherry-pick|clean|clone|commit|fetch|init|merge|mv|pull|push|rebase|reflog|remote|reset|restore|revert|rm|stash|submodule|switch|tag|worktree)\\b",
        "regex": true
      },
      {
        "pattern": "(?:^|[;&|()])\\s*git\\b(?:\\s+(?:(?:-C|-c|--git-dir|--work-tree|--namespace)\\s+\\S+|(?:--git-dir|--work-tree|--namespace)=\\S+|-[A-Za-z]+|--[A-Za-z0-9-]+))*\\s+push\\b[^;&|()]*(?:--force|-f)\\b",
        "regex": true
      },
      {
        "pattern": "(^|[;&|()\\s])gs\\s+(?:(?:upstack|downstack|branch|stack|repo|commit)\\s+)?(?:absorb|amend|checkout|continue|create|delete|onto|rename|rebase|restack|submit|sync)\\b",
        "regex": true
      },
      {
        "pattern": "(^|[;&|()\\s])sudo\\b",
        "regex": true
      },
      "chmod 777",
      {
        "pattern": "(^|[;&|()\\s])(?:curl|wget)\\b[^|;]*\\|\\s*(?:bash|sh)\\b",
        "regex": true
      }
    ]
  },
  "policies": {
    "rules": [
      {
        "id": "no-env-files",
        "patterns": [
          {
            "pattern": "**/.env"
          },
          {
            "pattern": "**/.env.*"
          },
          {
            "pattern": "**/credentials*"
          },
          {
            "pattern": "**/secrets*"
          }
        ],
        "protection": "readOnly",
        "enabled": true
      },
      {
        "id": "no-pi-auth-material",
        "patterns": [
          {
            "pattern": "auth.json"
          },
          {
            "pattern": "mcp-oauth/**"
          }
        ],
        "protection": "noAccess",
        "enabled": true
      },
      {
        "id": "no-git-internals",
        "patterns": [
          {
            "pattern": "**/.git/**"
          }
        ],
        "protection": "noAccess",
        "enabled": true
      }
    ]
  },
  "version": "0.9.0-20260327",
  "applyBuiltinDefaults": true,
  "onboarding": {
    "completed": true,
    "completedAt": "2026-05-03T00:00:00.000Z",
    "version": "0.9.0-20260327"
  }
}
