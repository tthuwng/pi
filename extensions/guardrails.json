{
  "$schema": "https://unpkg.com/@aliou/pi-guardrails@0.13.1/schema.json",
  "features": {
    "policies": true,
    "permissionGate": true,
    "pathAccess": false
  },
  "permissionGate": {
    "autoDenyPatterns": [
      {
        "pattern": "(?:^|[;&|()])\\s*rm\\b(?=[^;&|()]*\\s(?:-[A-Za-z]*[rR][A-Za-z]*|--recursive)\\b)(?=[^;&|()]*\\s(?:-[A-Za-z]*[fF][A-Za-z]*|--force)\\b)[^;&|()]*\\s(?:--\\s+)?(?:/|~/?|\\./?)(?=\\s|$|[;&|()])",
        "regex": true
      },
      ":(){ :|:& };:",
      {
        "pattern": "(^|[;&|()\\s])dd\\s+.*\\bof=/dev/",
        "regex": true
      },
      "mkfs",
      {
        "pattern": "(?:^|[;&|()])\\s*(?:(?:(?:env\\s+(?:(?:-[A-Za-z]+|--[A-Za-z0-9-]+(?:=\\S+)?|\\S+=\\S+)\\s+)*)|(?:command\\s+)))*(?:(?:/usr)?/bin/|/usr/local/bin/)?git\\b(?:\\s+(?:(?:-C|-c|--git-dir|--work-tree|--namespace)\\s+\\S+|(?:--git-dir|--work-tree|--namespace)=\\S+|-[A-Za-z]+|--[A-Za-z0-9-]+))*\\s+(?:clean\\b(?=[^;&|()]*\\s(?:-[A-Za-z]*[fF][A-Za-z]*|--force)\\b)|reset\\b(?=[^;&|()]*\\s--hard\\b)|branch\\b(?=[^;&|()]*\\s(?:-D|-d|--delete)\\b)|push\\b(?=[^;&|()]*(?:\\s--delete\\b|\\s:[^\\s;&|()]+)))",
        "regex": true
      },
      {
        "pattern": "(?:^|[;&|()])\\s*(?:(?:(?:env\\s+(?:(?:-[A-Za-z]+|--[A-Za-z0-9-]+(?:=\\S+)?|\\S+=\\S+)\\s+)*)|(?:command\\s+)))*(?:(?:/usr)?/bin/|/usr/local/bin/)?git\\b(?:\\s+(?:(?:-C|-c|--git-dir|--work-tree|--namespace)\\s+\\S+|(?:--git-dir|--work-tree|--namespace)=\\S+|-[A-Za-z]+|--[A-Za-z0-9-]+))*\\s+(?:config\\b(?=(?:(?![;&|()]).)*?(?:\\s(?:--add|--replace-all|--unset(?:-all)?|--rename-section|--remove-section)\\b|\\s+[A-Za-z0-9_][A-Za-z0-9_.-]*\\s+\\S+))(?![^;&|()]*\\s(?:--get|--get-all|--get-regexp|--list|-l)\\b)|notes\\s+(?:add|append|copy|edit|merge|prune|remove)\\b|credential\\s+(?:approve|reject)\\b)",
        "regex": true
      },
      {
        "pattern": "(?:^|[;&|()])\\s*(?:(?:(?:env\\s+(?:(?:-[A-Za-z]+|--[A-Za-z0-9-]+(?:=\\S+)?|\\S+=\\S+)\\s+)*)|(?:command\\s+)))*(?:(?:/usr)?/bin/|/usr/local/bin/)?git\\b(?:\\s+(?:(?:-C|-c|--git-dir|--work-tree|--namespace)\\s+\\S+|(?:--git-dir|--work-tree|--namespace)=\\S+|-[A-Za-z]+|--[A-Za-z0-9-]+))*\\s+push\\b[^;&|()]*(?:--force|-f|\\s\\+[^\\s;&|()]+)\\b",
        "regex": true
      },
      {
        "pattern": "(^|[;&|()\\s])sudo\\b",
        "regex": true
      },
      "chmod 777",
      {
        "pattern": "(^|[;&|()\\s])(?:curl|wget)\\b[^|;]*\\|\\s*(?:(?:/usr)?/bin/|/usr/local/bin/)?(?:bash|sh)\\b",
        "regex": true
      },
      {
        "pattern": "(^|[;&|()\\s])(?:(?:/usr)?/bin/|/usr/local/bin/)?(?:bash|sh)\\s+<\\(\\s*(?:curl|wget)\\b",
        "regex": true
      }
    ]
  },
  "policies": {
    "rules": [
      {
        "id": "no-env-files",
        "patterns": [
          {
            "pattern": "**/.env"
          },
          {
            "pattern": "**/.env.*"
          },
          {
            "pattern": "**/credentials*"
          },
          {
            "pattern": "**/secrets*"
          }
        ],
        "protection": "readOnly",
        "enabled": true
      },
      {
        "id": "no-pi-auth-material",
        "patterns": [
          {
            "pattern": "auth.json"
          },
          {
            "pattern": "mcp-oauth/**"
          }
        ],
        "protection": "noAccess",
        "enabled": true
      },
      {
        "id": "no-git-internals",
        "patterns": [
          {
            "pattern": "**/.git/**"
          }
        ],
        "protection": "noAccess",
        "enabled": true
      }
    ]
  },
  "version": "0.9.0-20260327",
  "applyBuiltinDefaults": true,
  "onboarding": {
    "completed": true,
    "completedAt": "2026-05-03T00:00:00.000Z",
    "version": "0.9.0-20260327"
  }
}
