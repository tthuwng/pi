{
  "features": {
    "policies": true,
    "permissionGate": true,
    "pathAccess": false
  },
  "permissionGate": {
    "explainCommands": false,
    "autoDenyPatterns": [
      "rm -rf /",
      "rm -rf ~",
      "rm -rf .",
      ":(){ :|:& };:",
      "dd if=/dev/",
      "mkfs",
      {
        "pattern": "(^|[;&|()\\s])git\\s+(?:-[A-Za-z]+(?:=\\S+)?\\s+|--[A-Za-z0-9-]+(?:=\\S+)?\\s+)*(?:add|am|apply|bisect|branch|checkout|cherry-pick|clean|clone|commit|fetch|init|merge|mv|pull|push|rebase|reflog|remote|reset|restore|revert|rm|stash|submodule|switch|tag|worktree)\\b",
        "regex": true
      },
      {
        "pattern": "(^|[;&|()\\s])git\\s+(?:-[A-Za-z]+(?:=\\S+)?\\s+|--[A-Za-z0-9-]+(?:=\\S+)?\\s+)*push\\s+.*(?:--force|-f)\\b",
        "regex": true
      },
      {
        "pattern": "(^|[;&|()\\s])gs\\s+(?:(?:upstack|downstack|branch|stack|repo|commit)\\s+)?(?:absorb|amend|checkout|continue|create|delete|onto|rename|rebase|restack|submit|sync)\\b",
        "regex": true
      },
      "sudo rm -rf",
      "chmod 777",
      "curl | bash",
      "curl | sh",
      "wget | bash",
      "wget | sh"
    ]
  },
  "policies": {
    "rules": [
      {
        "id": "no-env-files",
        "patterns": [
          { "pattern": "**/.env" },
          { "pattern": "**/.env.*" },
          { "pattern": "**/credentials*" },
          { "pattern": "**/secrets*" }
        ],
        "protection": "readOnly",
        "enabled": true
      },
      {
        "id": "no-git-internals",
        "patterns": [
          { "pattern": "**/.git/**" }
        ],
        "protection": "noAccess",
        "enabled": true
      }
    ]
  },
  "version": "0.9.0-20260327",
  "applyBuiltinDefaults": true,
  "onboarding": {
    "completed": true,
    "completedAt": "2026-05-03T00:00:00.000Z",
    "version": "0.9.0-20260327"
  }
}
