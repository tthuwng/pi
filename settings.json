{
  "defaultProvider": "openai-codex",
  "defaultModel": "gpt-5.5",
  "defaultThinkingLevel": "high",
  "theme": "gruvbox-custom",
  "quietStartup": true,
  "steeringMode": "all",
  "followUpMode": "all",
  "collapseChangelog": true,
  "enableInstallTelemetry": false,
  "branchSummary": {
    "skipPrompt": true
  },
  "hideThinkingBlock": true,
  "terminal": {
    "showImages": true,
    "imageWidthCells": 80,
    "showTerminalProgress": true
  },
  "editorPaddingX": 0,
  "retry": {
    "maxRetries": 3,
    "baseDelayMs": 2000
  },
  "lastChangelogVersion": "0.73.1",
  "transport": "auto",
  "compaction": {
    "enabled": true,
    "reserveTokens": 16384,
    "keepRecentTokens": 20000
  },
  "pi-memory-md": {
    "enabled": true,
    "memoryDir": {
      "localPath": "~/.pi/memory-md",
      "globalMemory": "common"
    },
    "delivery": "system-prompt",
    "hooks": {
      "sessionStart": [],
      "sessionEnd": []
    },
    "tape": {
      "enabled": false
    }
  },
  "packages": [
    "extensions/claude-ui",
    "packages/pi-subagents",
    "npm:pi-mcp-adapter",
    "npm:pi-lens",
    "npm:pi-web-access",
    "packages/pi-memory-md",
    "npm:@aliou/pi-guardrails",
    "npm:@aliou/pi-toolchain",
    "packages/pi-rewind",
    "npm:pi-ask-user",
    {
      "source": "npm:context-mode",
      "skills": [
        "context-mode"
      ]
    },
    "npm:pi-intercom"
  ],
  "subagents": {
    "agentOverrides": {
      "scout": {
        "disabled": true
      },
      "worker": {
        "disabled": true
      },
      "reviewer": {
        "disabled": true
      }
    }
  },
  "autocompleteMaxVisible": 10,
  "doubleEscapeAction": "tree"
}