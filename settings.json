{
  "defaultProvider": "openai-codex",
  "defaultModel": "gpt-5.5",
  "defaultThinkingLevel": "high",
  "theme": "gruvbox-custom",
  "quietStartup": true,
  "steeringMode": "all",
  "followUpMode": "all",
  "collapseChangelog": true,
  "enableInstallTelemetry": false,
  "branchSummary": {
    "skipPrompt": true
  },
  "hideThinkingBlock": true,
  "terminal": {
    "showImages": true,
    "imageWidthCells": 80,
    "showTerminalProgress": true
  },
  "editorPaddingX": 0,
  "retry": {
    "maxRetries": 3,
    "baseDelayMs": 2000
  },
  "lastChangelogVersion": "0.73.1",
  "transport": "auto",
  "compaction": {
    "enabled": true,
    "reserveTokens": 24000,
    "keepRecentTokens": 20000
  },
  "slipstreamCompact": {
    "enabled": true,
    "autoTrigger": true,
    "triggerContextPercent": 0.6,
    "slipstreamKeepRecentTokens": 50000,
    "compactionStrategy": "direct",
    "summaryModel": "openai-codex/gpt-5.5",
    "judgeModel": "openai-codex/gpt-5.5",
    "judgeThreshold": 7,
    "repairAttempts": 3,
    "rejectedSummaryMode": "ask",
    "pendingTtlMs": 300000,
    "artifactRoot": ".scratch/compactions"
  },
  "pi-memory-md": {
    "enabled": true,
    "memoryDir": {
      "localPath": "~/.pi/memory-md",
      "globalMemory": "common"
    },
    "delivery": "system-prompt",
    "hooks": {
      "sessionStart": [],
      "sessionEnd": []
    },
    "tape": {
      "enabled": false
    }
  },
  "packages": [
    "extensions/claude-ui",
    "packages/pi-subagents",
    "npm:pi-mcp-adapter",
    {
      "source": "npm:pi-lens",
      "skills": [
        "!ast-grep",
        "!lsp-navigation"
      ]
    },
    "npm:pi-web-access",
    "packages/pi-memory-md",
    "npm:@aliou/pi-guardrails",
    "npm:@aliou/pi-toolchain",
    {
      "source": "npm:pi-ask-user",
      "skills": []
    },
    {
      "source": "packages/context-mode",
      "skills": [
        "context-mode",
        "ctx-doctor"
      ]
    },
    "npm:pi-intercom",
    "packages/pi-codex-retry",
    "packages/pi-slipstream-compact",
    "packages/pi-goal-supervisor"
  ],
  "subagents": {
    "disableBuiltins": false
  },
  "autocompleteMaxVisible": 10,
  "doubleEscapeAction": "tree"
}