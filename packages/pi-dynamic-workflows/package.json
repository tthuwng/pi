{
  "name": "pi-dynamic-workflows",
  "version": "0.2.0",
  "description": "Claude Code-style dynamic workflow orchestration for Pi, backed by pi-subagents.",
  "type": "module",
  "license": "MIT",
  "author": "tthuwng",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tthuwng/pi-dynamic-workflows.git"
  },
  "homepage": "https://github.com/tthuwng/pi-dynamic-workflows#readme",
  "bugs": {
    "url": "https://github.com/tthuwng/pi-dynamic-workflows/issues"
  },
  "keywords": [
    "pi-package",
    "pi-extension",
    "dynamic-workflows",
    "subagents",
    "workflow"
  ],
  "files": [
    "src/",
    "prompts/",
    "skills/",
    "workflows/",
    "README.md",
    "package.json"
  ],
  "scripts": {
    "test": "tsc -p tsconfig.test.json && node --test .scratch/test-build/tests/*.test.js",
    "typecheck": "tsc --noEmit",
    "check": "npm test && npm run typecheck"
  },
  "pi": {
    "extensions": [
      "./src/index.ts"
    ],
    "skills": [
      "./skills"
    ],
    "prompts": [
      "./prompts"
    ]
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "typescript": "^5.9.3"
  }
}
