{
  "mcpServers": {
    "context7": {
      "command": "context7-mcp",
      "args": [],
      "lifecycle": "lazy"
    },
    "tree-sitter": {
      "command": "bash",
      "args": [
        "-lc",
        "agent_dir=\"${PI_CODING_AGENT_DIR:-${PI_AGENT_DIR:-$HOME/.pi/agent}}\"; exec node \"$agent_dir/mcp-servers/tree-sitter/index.mjs\""
      ],
      "directTools": [
        "search_symbols",
        "document_symbols",
        "symbol_definition",
        "pattern_search",
        "codebase_overview",
        "codebase_map"
      ],
      "lifecycle": "keep-alive"
    },
    "context-mode": {
      "command": "context-mode",
      "lifecycle": "lazy"
    },
    "google_docs": {
      "command": "bash",
      "args": [
        "-lc",
        "set -e; set -a; source \"${PI_CONFIG_DIR:-$HOME/.config/pi}/mcp-oauth/google_docs/env.sh\"; set +a; export npm_config_ignore_scripts=true; exec npx -y @a-bonus/google-docs-mcp@1.10.0"
      ],
      "lifecycle": "lazy"
    },
    "slack": {
      "command": "bash",
      "args": [
        "-lc",
        "set -e; set -a; source \"${PI_CONFIG_DIR:-$HOME/.config/pi}/mcp-oauth/slack/env.sh\"; set +a; exec \"${PI_SLACK_MCP_SERVER_BIN:-$HOME/.local/bin/slack-mcp-server-patched}\" --transport stdio"
      ],
      "lifecycle": "lazy"
    }
  }
}
