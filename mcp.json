{
  "mcpServers": {
    "context7": {
      "command": "context7-mcp",
      "args": [],
      "lifecycle": "lazy"
    },
    "nvim": {
      "command": "uvx",
      "args": ["nvim-mcp"],
      "lifecycle": "lazy"
    },
    "tree-sitter": {
      "command": "node",
      "cwd": "/home/orestes/.pi/agent",
      "args": ["mcp-servers/tree-sitter/index.mjs"],
      "directTools": ["search_symbols", "document_symbols", "symbol_definition", "pattern_search", "codebase_overview", "codebase_map"],
      "lifecycle": "keep-alive"
    },
    "context-mode": {
      "command": "context-mode",
      "lifecycle": "lazy"
    },
    "notion": {
      "url": "https://mcp.notion.com/mcp",
      "lifecycle": "lazy"
    },
    "google_docs": {
      "command": "bash",
      "args": [
        "-lc",
        "set -a; source /home/orestes/.config/pi/mcp-oauth/google_docs/env.sh; set +a; export npm_config_ignore_scripts=true; exec npx -y @a-bonus/google-docs-mcp@1.10.0"
      ],
      "lifecycle": "lazy"
    }
  }
}
