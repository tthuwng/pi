{
  "mcpServers": {
    "context7": {
      "command": "context7-mcp",
      "args": [],
      "lifecycle": "keep-alive"
    },
    "tree-sitter": {
      "command": "bash",
      "args": [
        "-lc",
        "agent_dir=\"${PI_CODING_AGENT_DIR:-${PI_AGENT_DIR:-$HOME/.pi/agent}}\"; exec node \"$agent_dir/mcp-servers/tree-sitter/index.mjs\""
      ],
      "directTools": [
        "search_symbols",
        "document_symbols",
        "symbol_definition",
        "pattern_search",
        "codebase_overview",
        "codebase_map"
      ],
      "lifecycle": "keep-alive"
    },
    "context-mode": {
      "command": "context-mode",
      "lifecycle": "keep-alive"
    }
  }
}
